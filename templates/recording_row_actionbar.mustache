{{!
    @template bbbext_bnx/recording_row_actionbar

    Render the action buttons for a single recording entry.

    Example context (json):
    {
        "id": "recording-actionbar-123",
        "recordingid": "123",
        "tools": [
            {
                "url": "#",
                "id": "recording-protect-123",
                "classes": "action-icon",
                "attributes": [
                    {"name": "data-action", "value": "protect"},
                    {"name": "data-require-confirmation", "value": "0"}
                ],
                "text": "Protect"
            },
            {
                "disabled": true,
                "classes": "action-icon iconsmall disabled",
                "icon": {
                    "key": "i/lock",
                    "component": "moodle",
                    "title": "Protect"
                },
                "attributes": [
                    {"name": "id", "value": "disabled-recording-protect-123"},
                    {"name": "aria-disabled", "value": "true"}
                ],
                "text": ""
            }
        ]
    }
}}
<div {{#id}}id="{{.}}"{{/id}} {{#recordingid}}data-recordingid="{{.}}"{{/recordingid}}>
    <div class="d-flex flex-row">
        {{#tools}}
            <div>
                {{>core/action_link}}
            </div>
        {{/tools}}
    </div>
</div>
