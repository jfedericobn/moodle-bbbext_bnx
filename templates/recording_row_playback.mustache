{{!
    @template bbbext_bnx/recording_row_playback

    Render the playback links for a single recording entry.

    Example context (json):
    {
        "id": "playbacks-abc",
        "dataimported": "1",
        "recordingid": "abc",
        "additionaloptions": "{\"foo\":\"bar\"}",
        "playbacks": [
            {
                "url": "https://example.org/playback",
                "id": "recording-play-presentation-abc",
                "classes": "btn btn-sm btn-default",
                "attributes": [
                    {"name": "data-action", "value": "play"},
                    {"name": "data-target", "value": "presentation"},
                    {"name": "target", "value": "_blank"},
                    {"name": "rel", "value": "noopener noreferrer"}
                ],
                "text": "Presentation"
            }
        ]
    }
}}
<div {{#id}}id="{{.}}"{{/id}}
     {{#dataimported}}data-imported="{{.}}"{{/dataimported}}
     {{#recordingid}}data-recordingid="{{.}}"{{/recordingid}}
     {{#additionaloptions}}data-additionaloptions="{{.}}"{{/additionaloptions}}
     {{#dataimported}}title="{{#str}}view_recording_link_warning, bigbluebuttonbn{{/str}}"{{/dataimported}}>
    {{#playbacks}}
        <span>
            {{>core/action_link}}
        </span>
    {{/playbacks}}
</div>
